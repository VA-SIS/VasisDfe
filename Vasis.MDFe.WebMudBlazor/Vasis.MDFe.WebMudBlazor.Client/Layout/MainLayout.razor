@inherits LayoutComponentBase

@* O using abaixo está correto para o seu caso, apontando para a pasta 'Layout'. *@
@using Vasis.MDFe.WebMudBlazor.Client.Layout

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h5" Class="ml-3">Vasis MDFe</MudText>
        <MudSpacer />
        @* Se você tiver um componente LoginDisplay, verifique seu caminho e namespace! *@
        @* <LoginDisplay /> *@ 
        <MudIconButton Icon="@Icons.Custom.Brands.GitHub" Href="https://github.com/ZeusAutomacao/DFe.NET" Target="_blank" Color="Color.Inherit" />
    </MudAppBar>

    @* CORREÇÃO ANTERIOR: A propriedade Variant="MudBlazor.DrawerVariant.Persistent" foi adicionada ao MudDrawer para evitar sobreposição. *@
    <MudDrawer @bind-Open="_drawerOpen" Elevation="1" Variant="MudBlazor.DrawerVariant.Persistent">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">Vasis MDFe Menu</MudText>
        </MudDrawerHeader>
        <NavMenu /> @* Este é o componente NavMenu que contém os links *@
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="my-8 pt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = true;

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }
}